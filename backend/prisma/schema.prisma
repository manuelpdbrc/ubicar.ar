// ─── ubicar.ar — Prisma Schema ────────────────────────────────
// MariaDB (Hostinger Business), connection_limit=3 in DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────

enum GlobalRole {
  USER
  ADMIN
}

enum CollectionRole {
  CREATOR
  EDITOR
  VIEWER
}

enum VisitType {
  SPONTANEOUS
  CIRCUIT
}

enum CircuitStatus {
  PENDING
  PENDING_EXPIRED
  COMPLETED
}

// ─── Models ─────────────────────────────────────────────────

model User {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar(100)
  email      String     @unique @db.VarChar(255)
  password   String     @db.VarChar(255)
  globalRole GlobalRole @default(USER)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  categoriesCreated     Category[]
  locationsCreated      Location[]
  collectionsCreated    Collection[]
  collectionPermissions CollectionUserPermission[]
  visits                Visit[]
  circuitsAssigned      Circuit[]

  @@map("users")
}

model Category {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  color           String   @default("#3B82F6") @db.VarChar(7)
  createdByUserId Int
  createdByUser   User     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  locations Location[]

  @@index([createdByUserId])
  @@map("categories")
}

model Location {
  id              Int       @id @default(autoincrement())
  uniqueCode      String    @unique @default(uuid()) @db.VarChar(36)
  name            String    @db.VarChar(255)
  latitude        Float
  longitude       Float
  imageUrl        String?   @db.VarChar(500)
  categoryId      Int
  category        Category  @relation(fields: [categoryId], references: [id])
  createdByUserId Int
  createdByUser   User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  collectionLocations CollectionLocation[]
  visits              Visit[]

  @@index([categoryId])
  @@index([createdByUserId])
  @@map("locations")
}

model Collection {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  createdByUserId Int
  createdByUser   User     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  locations   CollectionLocation[]
  permissions CollectionUserPermission[]
  circuits    Circuit[]

  @@index([createdByUserId])
  @@map("collections")
}

model CollectionLocation {
  collectionId Int
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  locationId   Int
  location     Location   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  addedAt      DateTime   @default(now())

  @@id([collectionId, locationId])
  @@index([locationId])
  @@map("collection_locations")
}

model CollectionUserPermission {
  collectionId Int
  collection   Collection     @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  userId       Int
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         CollectionRole
  createdAt    DateTime       @default(now())

  @@id([collectionId, userId])
  @@index([userId])
  @@map("collection_user_permissions")
}

model Visit {
  id            Int       @id @default(autoincrement())
  clientId      String?   @unique @db.VarChar(36)
  locationId    Int
  location      Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId        Int
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateTimestamp DateTime  @default(now())
  comment       String?   @db.Text
  imageUrl      String?   @db.VarChar(500)
  type          VisitType @default(SPONTANEOUS)
  circuitId     Int?
  circuit       Circuit?  @relation(fields: [circuitId], references: [id], onDelete: SetNull)

  @@index([locationId])
  @@index([userId])
  @@index([circuitId])
  @@map("visits")
}

model Circuit {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(255)
  collectionId       Int
  collection         Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  assignedOperatorId Int
  assignedOperator   User          @relation(fields: [assignedOperatorId], references: [id])
  expirationDate     DateTime
  status             CircuitStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  visits Visit[]

  @@index([collectionId])
  @@index([assignedOperatorId])
  @@index([status])
  @@map("circuits")
}
