{
  "name": "ubicar-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx nodemon src/index.ts",
    "build": "cd ../frontend && npm install --include=dev && npm run build && cd ../backend && npx tsc && node -e \"const fs=require('fs'); fs.rmSync('public', {recursive:true, force:true}); fs.cpSync('../frontend/dist', 'public', {recursive:true});\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.12.0",
    "typescript": "^5.7.0",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2"
  }
}
